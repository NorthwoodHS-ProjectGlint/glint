{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Native)",
      "description": "Build for the native host platform",
      "binaryDir": "${sourceDir}/_build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "rpi4-aarch64",
      "displayName": "Raspberry Pi 4B (aarch64)",
      "description": "Cross-compile for Raspberry Pi 4B (ARM64)",
      "binaryDir": "${sourceDir}/_build-rpi4",
      "toolchainFile": "${sourceDir}/toolchain-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "GLINT_BUILD_EXAMPLES": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "jobs": 0
    },
    {
      "name": "rpi4-aarch64",
      "configurePreset": "rpi4-aarch64",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    }
  ]
}
